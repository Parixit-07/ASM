# Server configuration
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/asha-shop
JWT_SECRET=change-this-secret

# Supabase (optional)
# Create a project at https://app.supabase.com, then copy these values
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Set to true to seed example product data on startup
SEED_DATA=true
